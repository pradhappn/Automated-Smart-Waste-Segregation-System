# Server Configuration
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/waste-segregation?retryWrites=true&w=majority
# EXAMPLE: mongodb+srv://admin:Password123@wastecluster.xxxxxx.mongodb.net/waste-segregation?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# API Configuration
CORS_ORIGIN=*
API_PREFIX=/api

# Logging
LOG_LEVEL=debug
